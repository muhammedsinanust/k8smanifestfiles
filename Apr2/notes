### RBAC
-----------------------------------------
# create key
openssl genrsa -out raj.key 2048
# create csr
openssl req -new -key raj.key -out raj.csr -subj "/CN=raj/O=dev-team"
# sign csr using kubernetes CA / create crt
# ( CertificateSigningRequest )
openssl x509 -req -in raj.csr \
 -CA /etc/kubernetes/pki/ca.crt \
 -CAkey /etc/kubernetes/pki/ca.key \
 -CAcreateserial \
 -out raj.crt -days 365
# see the certificate
openssl x509 -in raj.crt -text -noout
# create config for user
kubectl config set-credentials raj \
 --client-certificate=raj.crt \
 --client-key=raj.key
# set context for user
kubectl config set-context raj-context \
 --cluster=kubernetes \
 --user=raj
# see the config file
cat $HOME/.kube/config
# switch context to user context
kubectl config use-context raj-context
-------------------------------------------
# ls -l | grep raj
-rw-r--r--  1 root root 1009 Apr  2 09:22 raj.crt
-rw-r--r--  1 root root  907 Apr  2 09:18 raj.csr
-rw-------  1 root root 1704 Apr  2 09:13 raj.key


